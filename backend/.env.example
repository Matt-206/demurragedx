# backend/.env.example
# Copy to .env for local development.
# In Railway: set these under your service → Variables tab.

# ── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Override only if needed locally.
PORT=3001

# Set to 'production' in Railway.
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL. Railway uses this to allow cross-origin requests.
# Example: https://demurragedx.vercel.app
# Leave blank locally — localhost:5173 is always allowed.
ALLOWED_ORIGIN=

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
# Railway: set to /data/demurragedx.db and mount a volume at /data.
# Local: leave blank to use the default ./db/demurragedx.db path.
DB_PATH=

# ── AIS Data ──────────────────────────────────────────────────────────────────
# VesselFinder / VesselTracker API key for live vessel positions.
# Register free at https://www.vesseltracker.com/app/api.html
# Leave blank to use realistic mock vessels (demo mode).
AIS_API_KEY=
