# frontend/.env.example
# Copy to .env.local for local development overrides.
# In Vercel: set these in the dashboard under Settings → Environment Variables.

# OPTIONAL. Leave blank when using vercel.json rewrites (recommended).
# Set to your Railway URL only if you want the browser to call Railway directly
# instead of going through the Vercel edge proxy.
# Example: https://demurragedx-production.up.railway.app
VITE_API_URL=
